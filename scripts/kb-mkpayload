#!/usr/bin/env python3
"""
Generate a 512-byte Fusion RGB keyboard payload.

Usage:
  kb-mkpayload solid FF6600           -> all keys one color (# optional)
  kb-mkpayload alternate FF0000 0000FF -> alternating two colors
  kb-mkpayload gradient FF0000 0000FF  -> gradient across keys
  Add: out <file.bin>                  -> write to file instead of stdout
"""
import sys

# Key map: slot index -> key name (128 slots, 'no' = unused/padding)
KEYMAP = [
    'no','no','no','no','no','no',
    'ctrl_l','shift_l','capslock','tab','grave','esc',
    'fn','backslash','a','q','1','f1',
    'win','y','s','w','2','f2',
    'alt_l','x','d','e','3','f3',
    'no','c','f','r','4','f4',
    'no','v','g','t','5','f5',
    'space','b','h','z','6','f6',
    'no','n','j','u','7','f7',
    'no','m','k','i','8','f8',
    'alt_r','comma','l','o','9','f9',
    'menu','period','semicolon','p','0','f10',
    'ctrl_r','minus','quote','bracket_l','equal','f11',
    'no','no','no','plus','backtick','f12',
    'left','shift_r','hash','no','no','break',
    'down','up','enter','no','backspace','delete',
    'right',
    'num1','num4','num7','numlk','home',
    'num0','num2','num5','num8','num_slash','pageup',
    'num_comma','num3','num6','num9','num_star','pagedown',
    'num_enter','no','num_plus','no','num_minus','end',
    'no','no','no','no','no','no','no','no'
]

def parse_hex(h):
    """Parse a hex color string like #FF6600 or FF6600 into (R, G, B)."""
    original = h
    h = h.lstrip('#')
    if len(h) != 6:
        print(f"Error: '{original}' is not a valid hex color.", file=sys.stderr)
        print(f"Use 6-digit hex format: #RRGGBB or RRGGBB (e.g. #FF6600 or FF6600)", file=sys.stderr)
        sys.exit(1)
    try:
        return tuple(int(h[i:i+2], 16) for i in (0, 2, 4))
    except ValueError:
        print(f"Error: '{original}' is not a valid hex color.", file=sys.stderr)
        print(f"Use 6-digit hex format: #RRGGBB or RRGGBB (e.g. #FF6600 or FF6600)", file=sys.stderr)
        sys.exit(1)

def is_hex_color(s):
    """Return True if s looks like a hex color argument."""
    h = s.lstrip('#')
    if len(h) != 6:
        return False
    try:
        int(h, 16)
        return True
    except ValueError:
        return False

def make_payload(colors_by_slot):
    """
    Build 512-byte payload. Byte order per key slot: 0x00, R, G, B
    (empirically determined on Gigabyte AERO 15 Studio XB, 1044:7a3f)
    """
    out = bytearray(512)
    for i, (r, g, b) in enumerate(colors_by_slot):
        out[i*4]   = 0x00
        out[i*4+1] = r
        out[i*4+2] = g
        out[i*4+3] = b
    return bytes(out)

def solid(color):
    return make_payload([color] * 128)

def alternate(c1, c2):
    return make_payload([c1 if i % 2 == 0 else c2 for i in range(128)])

def gradient(c1, c2):
    def lerp(a, b, t): return int(a + (b - a) * t)
    slots = []
    for i in range(128):
        t = i / 127.0
        slots.append(tuple(lerp(c1[j], c2[j], t) for j in range(3)))
    return make_payload(slots)

if __name__ == '__main__':
    if len(sys.argv) < 2:
        print(__doc__); sys.exit(1)

    cmd = sys.argv[1]
    args = sys.argv[2:]

    # parse optional 'out <file>' at end
    outfile = None
    out_idx = None
    for i, a in enumerate(args):
        if a == 'out':
            out_idx = i
            break
    if out_idx is not None:
        if out_idx + 1 >= len(args):
            print("Error: 'out' requires a filename argument", file=sys.stderr)
            sys.exit(1)
        outfile = args[out_idx + 1]
        args = args[:out_idx]

    # validate that color args look like hex, not named colors
    for a in args:
        if a and not is_hex_color(a):
            print(f"Error: '{a}' is not a valid hex color.", file=sys.stderr)
            print(f"Named colors (red, blue, etc.) only work with preset modes.", file=sys.stderr)
            print(f"For solid/alternate/gradient, use hex: #RRGGBB or RRGGBB (e.g. #FF6600)", file=sys.stderr)
            sys.exit(1)

    if cmd == 'solid':
        if len(args) < 1:
            print("Usage: kb-mkpayload solid #RRGGBB", file=sys.stderr); sys.exit(1)
        payload = solid(parse_hex(args[0]))
    elif cmd == 'alternate':
        if len(args) < 2:
            print("Usage: kb-mkpayload alternate #RRGGBB #RRGGBB", file=sys.stderr); sys.exit(1)
        payload = alternate(parse_hex(args[0]), parse_hex(args[1]))
    elif cmd == 'gradient':
        if len(args) < 2:
            print("Usage: kb-mkpayload gradient #RRGGBB #RRGGBB", file=sys.stderr); sys.exit(1)
        payload = gradient(parse_hex(args[0]), parse_hex(args[1]))
    else:
        print(f"Error: Unknown command '{cmd}'", file=sys.stderr)
        print(f"Valid commands: solid, alternate, gradient", file=sys.stderr)
        sys.exit(1)

    if outfile:
        with open(outfile, 'wb') as f:
            f.write(payload)
        print(f"Written {len(payload)} bytes to {outfile}")
    else:
        sys.stdout.buffer.write(payload)
